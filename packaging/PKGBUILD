# Maintainer: CodexBar Linux Sidebar contributors
pkgname=codexbar-linux-sidebar
pkgver=0.1.0
pkgrel=1
pkgdesc="Quickshell sidebar for CodexBar provider usage on Linux"
arch=('x86_64' 'aarch64')
url="https://github.com/rabesss/codexbar-linux-sidebar"
license=('MIT')
depends=('quickshell')
makedepends=('cargo' 'curl')
optdepends=(
  'codexbar: upstream CLI (or run scripts/fetch-codexbar-cli.sh post-install)'
)
source=("$pkgname-$pkgver.tar.gz")
sha256sums=('SKIP')

prepare() {
  cd "$pkgname-$pkgver"
  cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
  cd "$pkgname-$pkgver"
  cargo build --release
}

package() {
  cd "$pkgname-$pkgver"
  install -Dm755 target/release/codexbar-sidebard "$pkgdir/usr/bin/codexbar-sidebard"
  install -Dm755 target/release/codexbar-sidebarctl "$pkgdir/usr/bin/codexbar-sidebarctl"
  install -dm755 "$pkgdir/usr/share/codexbar-linux-sidebar/quickshell"
  cp -a quickshell/. "$pkgdir/usr/share/codexbar-linux-sidebar/quickshell/"
  install -Dm644 examples/config.example.toml "$pkgdir/usr/share/codexbar-linux-sidebar/config.example.toml"
  install -Dm644 systemd/codexbar-sidebard.service "$pkgdir/usr/lib/systemd/user/codexbar-sidebard.service"
  install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}
